{
  "version": 2,
  "builds": [
    {
      "src": "server-prod.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/server-prod.js"
    },
    {
      "src": "/tax-calculator",
      "dest": "/server-prod.js"
    },
    {
      "src": "/(.*)",
      "dest": "/server-prod.js"
    }
  ]
}